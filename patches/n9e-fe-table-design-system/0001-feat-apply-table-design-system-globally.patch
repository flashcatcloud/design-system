@@ -0,0 +1,94 @@
+import React, { useMemo, useState } from 'react';
+import { Button, Checkbox, Input } from 'antd';
+import { SearchOutlined } from '@ant-design/icons';
+import { useTranslation } from 'react-i18next';
+
+export interface TableFilterOption {
+  label: React.ReactNode;
+  searchText: string;
+  value: React.Key;
+}
+
+export function normalizeTableFilterOptions(filters?: any[]): TableFilterOption[] {
+  return (filters || []).flatMap((item) => {
+    const current = item?.value !== undefined
+      ? [
+          {
+            label: item.text,
+            searchText: typeof item.text === 'string' ? item.text : String(item.value ?? ''),
+            value: item.value,
+          },
+        ]
+      : [];
+    return [...current, ...normalizeTableFilterOptions(item?.children)];
+  });
+}
+
+interface Props {
+  clearFilters?: () => void;
+  confirm: () => void;
+  filters?: any[];
+  selectedKeys?: React.Key[];
+  setSelectedKeys: (keys: React.Key[]) => void;
+  showSearch?: boolean;
+}
+
+export default function TableFilterDropdown(props: Props) {
+  const { t } = useTranslation();
+  const { clearFilters, confirm, filters, selectedKeys = [], setSelectedKeys, showSearch } = props;
+  const [keyword, setKeyword] = useState('');
+  const options = useMemo(() => normalizeTableFilterOptions(filters), [filters]);
+  const shouldShowSearch = showSearch ?? options.length > 8;
+  const filteredOptions = options.filter((option) => option.searchText.toLowerCase().includes(keyword.trim().toLowerCase()));
+
+  return (
+    <div className='fc-table-filter-panel'>
+      {shouldShowSearch && (
+        <div className='fc-table-filter-search'>
+          <Input
+            allowClear
+            autoFocus
+            size='small'
+            prefix={<SearchOutlined />}
+            placeholder={t('在筛选项中搜索')}
+            value={keyword}
+            onChange={(event) => setKeyword(event.target.value)}
+          />
+        </div>
+      )}
+      <div className='fc-table-filter-options'>
+        {filteredOptions.map((option) => {
+          const checked = selectedKeys.includes(option.value);
+          return (
+            <div
+              className={`fc-table-filter-option${checked ? ' is-selected' : ''}`}
+              key={String(option.value)}
+              onClick={() => {
+                setSelectedKeys(checked ? selectedKeys.filter((value) => value !== option.value) : [...selectedKeys, option.value]);
+              }}
+            >
+              <Checkbox checked={checked} />
+              <span className='fc-table-filter-option-label'>{option.label}</span>
+            </div>
+          );
+        })}
+      </div>
+      <div className='ant-table-filter-dropdown-btns'>
+        <Button
+          size='small'
+          type='link'
+          onClick={() => {
+            setKeyword('');
+            clearFilters?.();
+            confirm();
+          }}
+        >
+          {t('重置')}
+        </Button>
+        <button className='ant-btn ant-btn-primary ant-btn-sm fc-table-filter-confirm-button' type='button' onClick={() => confirm()}>
+          <span>确定</span>
+        </button>
+      </div>
+    </div>
+  );
+}
diff --git a/src/components/EnhancedTable/index.tsx b/src/components/EnhancedTable/index.tsx
new file mode 100644
index 000000000..70dc0b9ac
--- /dev/null
+++ b/src/components/EnhancedTable/index.tsx
@@ -0,0 +1,102 @@
+import React, { useMemo } from 'react';
+import { Table, TableProps } from 'antd';
+import { useTranslation } from 'react-i18next';
+import './style.less';
+import { ColumnType } from 'antd/lib/table';
+import _ from 'lodash';
+import TableFilterDropdown from './TableFilterDropdown';
+import TableActionDropdown from './TableActionDropdown';
+
+interface IProps<RecordType = any> extends TableProps<RecordType> {}
+
+function isActionTitle(title: React.ReactNode) {
+  if (typeof title !== 'string') {
+    return false;
+  }
+  const normalizedTitle = title.toLowerCase();
+  return ['操作', '操作列', 'operation', 'operations', 'action', 'actions'].includes(normalizedTitle);
+}
+
+/**
+ * 基于antd的Table组件, 对部分属性的默认值修改
+ *
+ * Table 更改:
+ * 1. 默认size = small
+ *
+ * columns 更改:
+ * 1. 默认ellipsis = true
+ * 2. 默认排序, 操作列 dataIndex = 'operate' 或 sorter = false 不排序, 默认排序为字符串参数, 特殊字段需自定义排序
+ *
+ * @param props
+ * @returns
+ */
+export default function EnhancedTable<RecordType extends object = any>(props: IProps<RecordType>) {
+  const { t, i18n } = useTranslation();
+  const { columns, size, pagination, ...rest } = props;
+
+  const enhancedColumns = useMemo(() => {
+    const enhanceColumn = (col: ColumnType<RecordType>): any => {
+      const dataIndex = col.dataIndex;
+      const dataIndexKey = Array.isArray(dataIndex) ? dataIndex.join('.') : dataIndex;
+      const isActionColumn =
+        (col as any).enhancedTableActionMenu !== false &&
+        (dataIndexKey === 'operate' ||
+          col.key === 'operate' ||
+          col.key === 'operation' ||
+          col.key === 'operations' ||
+          dataIndexKey === 'operation' ||
+          dataIndexKey === 'operations' ||
+          isActionTitle(col.title));
+      // 操作列不排序
+      const sorter =
+        col.sorter !== undefined
+          ? col.sorter
+          : !!dataIndex && !isActionColumn
+          ? (a, b) => {
+              // 只排序字符串参数
+              if (typeof _.get(a, dataIndex) === 'string' && typeof _.get(b, dataIndex) === 'string') {
+                return _.get(a, dataIndex).toLowerCase().localeCompare(_.get(b, dataIndex).toLowerCase());
+              }
+              return 0;
+            }
+          : false;
+      return {
+        ...col,
+        ellipsis: col.ellipsis !== undefined ? col.ellipsis : true,
+        sorter,
+        filterDropdown:
+          col.filterDropdown || !col.filters
+            ? col.filterDropdown
+            : (filterProps) => <TableFilterDropdown {...filterProps} filters={col.filters as any[]} showSearch={col.filterSearch as boolean | undefined} />,
+        render:
+          isActionColumn && col.render
+            ? (value, record, index) => {
+                const rendered = col.render?.(value, record, index);
+                if (rendered && typeof rendered === 'object' && !React.isValidElement(rendered) && 'children' in rendered) {
+                  return {
+                    ...rendered,
+                    children: <TableActionDropdown>{(rendered as any).children}</TableActionDropdown>,
+                  };
+                }
+                return <TableActionDropdown>{rendered as React.ReactNode}</TableActionDropdown>;
+              }
+            : col.render,
+        children: (col as any).children?.map(enhanceColumn),
+      };
+    };
+    return columns?.map((col: ColumnType<RecordType>) => enhanceColumn(col));
+  }, [columns]);
+
+  const enhancedPagination = useMemo(() => {
+    return {
+      showSizeChanger: true,
+      showQuickJumper: true,
+      showTotal: (total) => t('table-total', { count: total }),
+      defaultPageSize: 15,
+      pageSizeOptions: ['15', '20', '50', '100'],
+      ...pagination,
+    };
+  }, [pagination, i18n.language]);
+
+  return <Table columns={enhancedColumns || []} size={size || 'small'} pagination={enhancedPagination} {...rest} />;
+}
