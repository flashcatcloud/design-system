diff --git a/src/components/EnhancedTable/TableActionDropdown.tsx b/src/components/EnhancedTable/TableActionDropdown.tsx
new file mode 100644
index 000000000..e98c3f89b
--- /dev/null
+++ b/src/components/EnhancedTable/TableActionDropdown.tsx
@@ -0,0 +1,159 @@
+import React from 'react';
+import { Button, Dropdown, Menu, Space } from 'antd';
+import { Copy, Download, Edit3, Eye, MoreVertical, Play, Settings, Trash2 } from 'lucide-react';
+
+const triggerIconProps = { size: 14, strokeWidth: 1.17 };
+const menuIconProps = { size: 16, strokeWidth: 1.33 };
+
+function flattenActionNodes(node: React.ReactNode): React.ReactNode[] {
+  if (node === null || node === undefined || typeof node === 'boolean') {
+    return [];
+  }
+  if (Array.isArray(node)) {
+    return node.flatMap(flattenActionNodes);
+  }
+  if (!React.isValidElement(node)) {
+    return [node];
+  }
+  if (node.type === React.Fragment || node.type === Space) {
+    return React.Children.toArray(node.props.children).flatMap(flattenActionNodes);
+  }
+  return [node];
+}
+
+function getTextContent(node: React.ReactNode): string {
+  if (typeof node === 'string' || typeof node === 'number') {
+    return String(node);
+  }
+  if (Array.isArray(node)) {
+    return node.map(getTextContent).join('');
+  }
+  if (React.isValidElement(node)) {
+    return getTextContent(node.props.children);
+  }
+  return '';
+}
+
+function getDefaultIcon(label: string, danger?: boolean) {
+  if (danger || /删除|delete|remove/i.test(label)) return <Trash2 {...menuIconProps} />;
+  if (/查看|预览|view|preview/i.test(label)) return <Eye {...menuIconProps} />;
+  if (/编辑|edit/i.test(label)) return <Edit3 {...menuIconProps} />;
+  if (/克隆|复制|copy|clone/i.test(label)) return <Copy {...menuIconProps} />;
+  if (/配置|设置|setting|config/i.test(label)) return <Settings {...menuIconProps} />;
+  if (/执行|run|execute/i.test(label)) return <Play {...menuIconProps} />;
+  if (/导出|export|download/i.test(label)) return <Download {...menuIconProps} />;
+  return undefined;
+}
+
+function getButtonFromWrapper(node: React.ReactElement) {
+  const children = React.Children.toArray(node.props.children);
+  return children.find((child) => React.isValidElement(child) && child.type === Button) as React.ReactElement | undefined;
+}
+
+function containsExistingActionDropdown(node: React.ReactNode): boolean {
+  if (node === null || node === undefined || typeof node === 'boolean') {
+    return false;
+  }
+  if (Array.isArray(node)) {
+    return node.some(containsExistingActionDropdown);
+  }
+  if (!React.isValidElement(node)) {
+    return false;
+  }
+  if (node.type === Dropdown || node.props?.className?.includes?.('fc-table-more-button')) {
+    return true;
+  }
+  return React.Children.toArray(node.props.children).some(containsExistingActionDropdown);
+}
+
+function getActionMeta(node: React.ReactNode) {
+  if (React.isValidElement(node) && node.type === Button) {
+    const { children, danger, disabled, icon, onClick } = node.props;
+    const label = getTextContent(children);
+    return {
+      content: children,
+      danger,
+      disabled,
+      icon: icon || getDefaultIcon(label, danger),
+      onClick,
+    };
+  }
+
+  if (React.isValidElement(node)) {
+    const button = getButtonFromWrapper(node);
+    if (button) {
+      const { children, danger, disabled, icon } = button.props;
+      const label = getTextContent(children);
+      return {
+        content: React.cloneElement(node, undefined, <span>{children}</span>),
+        danger,
+        disabled,
+        icon: icon || getDefaultIcon(label, danger),
+      };
+    }
+  }
+
+  const label = getTextContent(node);
+  return {
+    content: node,
+    danger: /删除|delete|remove/i.test(label),
+    disabled: false,
+    icon: getDefaultIcon(label),
+  };
+}
+
+function renderActionItem(node: React.ReactNode, index: number) {
+  const { content, danger, disabled, icon, onClick } = getActionMeta(node);
+
+  return (
+    <Menu.Item danger={danger} disabled={disabled} icon={icon} key={index} onClick={onClick}>
+      {content}
+    </Menu.Item>
+  );
+}
+
+function renderActionItems(nodes: React.ReactNode[]) {
+  let insertedDangerDivider = false;
+  return nodes.flatMap((node, index) => {
+    const meta = getActionMeta(node);
+    const needsDivider = meta.danger && index > 0 && !insertedDangerDivider;
+    if (needsDivider) {
+      insertedDangerDivider = true;
+      return [<Menu.Divider key={`${index}-divider`} />, renderActionItem(node, index)];
+    }
+    return (
+      renderActionItem(node, index)
+    );
+  });
+}
+
+interface Props {
+  children: React.ReactNode;
+}
+
+export default function TableActionDropdown(props: Props) {
+  const actionNodes = flattenActionNodes(props.children);
+
+  if (!actionNodes.length) {
+    return null;
+  }
+
+  if (actionNodes.length === 1 && React.isValidElement(actionNodes[0]) && actionNodes[0].props?.className?.includes?.('fc-table-more-button')) {
+    return actionNodes[0];
+  }
+
+  if (actionNodes.length === 1 && containsExistingActionDropdown(actionNodes[0])) {
+    return actionNodes[0] as React.ReactElement;
+  }
+
+  return (
+    <Dropdown
+      overlay={<Menu>{renderActionItems(actionNodes)}</Menu>}
+      overlayClassName='fc-table-action-dropdown'
+      placement='bottomRight'
+      trigger={['hover', 'click']}
+    >
+      <Button className='fc-table-more-button' icon={<MoreVertical {...triggerIconProps} />} size='small' type='text' />
+    </Dropdown>
+  );
+}
diff --git a/src/components/EnhancedTable/TableFilterDropdown.tsx b/src/components/EnhancedTable/TableFilterDropdown.tsx
new file mode 100644
index 000000000..01a73b72f
