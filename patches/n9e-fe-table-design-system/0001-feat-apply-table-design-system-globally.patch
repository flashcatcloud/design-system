+  --pagination-border-active: var(--fc-border-color2);
+  --pagination-text-active: var(--fc-text-2);
+  --pagination-bg-active-hover: rgb(var(--fc-fill-5-rgb) / 0.4);
+  --pagination-border-active-hover: var(--fc-border-color2);
+  --pagination-text-active-hover: var(--fc-text-1);
+  --pagination-bg-disabled: transparent;
+  --pagination-border-disabled: transparent;
+  --pagination-text-disabled: var(--fc-text-5);
+  --pagination-arrow-color-default: var(--fc-text-3);
+  --pagination-arrow-color-hover: var(--fc-text-3);
+  --pagination-arrow-color-disabled: var(--fc-text-5);
